+locals {
+  zone_name = trimsuffix(data.aws_route53_zone.this.name, ".")
+  # Build the FQDN from the first A record entry and the zone name.
+  # "" → "infrahouse.com", "openclaw" → "openclaw.infrahouse.com"
+  fqdn = (
+    var.dns_a_records[0] == ""
+    ? local.zone_name
+    : "${var.dns_a_records[0]}.${local.zone_name}"
+  )
+
+  enable_bedrock = length(var.bedrock_model_ids) > 0
+
+  # Primary model depends on whether Bedrock is enabled
+  primary_model = (
+    local.enable_bedrock
+    ? "bedrock/anthropic.claude-sonnet-4-6-20250514"
+    : "anthropic/claude-sonnet-4-6-20250514"
+  )
+
+  # Model providers configured in openclaw.json
+  model_providers = merge(
+    local.enable_bedrock ? {
+      bedrock = {
+        region = "REGION_PLACEHOLDER"
+        api    = "anthropic-messages"
+      }
+    } : {},
+    {
+      anthropic = {}
+      openai    = {}
+      ollama = {
+        baseUrl = "http://127.0.0.1:11434/v1"
+        apiKey  = "ollama-local"
+        api     = "openai-completions"
+        models  = []
+      }
+    }
+  )
+
+  openclaw_config = {
+    gateway = {
+      mode = "local"
+      port = 5173
+      bind = "0.0.0.0"
+      auth = {
+        mode  = "token"
+        token = "GATEWAY_TOKEN_PLACEHOLDER"
+      }
+    }
+    agents = {
+      defaults = {
+        maxConcurrent = 4
+        compaction    = { mode = "safeguard" }
+        models = merge(
+          local.enable_bedrock ? { bedrock = {} } : {},
+          {
+            anthropic = {}
+            openai    = {}
+            ollama    = {}
+          }
+        )
+        model = {
+          primary = local.primary_model
+        }
+      }
+    }
+    models = {
+      providers = local.model_providers
+    }
+  }
+}
