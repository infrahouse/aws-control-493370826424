+#!/usr/bin/env bash
+set -euo pipefail
+
+OPENCLAW_HOME=/home/openclaw
+
+# API keys from Secrets Manager
+SECRET_JSON=$(ih-secrets get "${secret_name}")
+ANTHROPIC_API_KEY=$(echo "$SECRET_JSON" | jq -r '.ANTHROPIC_API_KEY // empty')
+OPENAI_API_KEY=$(echo "$SECRET_JSON" | jq -r '.OPENAI_API_KEY // empty')
+
+# Environment file for API keys
+echo "$${ANTHROPIC_API_KEY:+ANTHROPIC_API_KEY=$ANTHROPIC_API_KEY}" > "$OPENCLAW_HOME/.openclaw-env"
+echo "$${OPENAI_API_KEY:+OPENAI_API_KEY=$OPENAI_API_KEY}" >> "$OPENCLAW_HOME/.openclaw-env"
+chmod 600 "$OPENCLAW_HOME/.openclaw-env"
+chown openclaw:openclaw "$OPENCLAW_HOME/.openclaw-env"
+
+# Install OpenClaw
+su - openclaw -c 'npm install -g openclaw'
+
+# Gateway token
+GATEWAY_TOKEN=$(openssl rand -hex 32)
+
+# OpenClaw configuration
+mkdir -p "$OPENCLAW_HOME/.openclaw"
+cat > "$OPENCLAW_HOME/.openclaw/openclaw.json" <<'CFGEOF'
+${openclaw_config_json}
+CFGEOF
+sed -i "s/GATEWAY_TOKEN_PLACEHOLDER/$GATEWAY_TOKEN/g" "$OPENCLAW_HOME/.openclaw/openclaw.json"
+%{ if enable_bedrock ~}
+sed -i "s/REGION_PLACEHOLDER/${region}/g" "$OPENCLAW_HOME/.openclaw/openclaw.json"
+%{ endif ~}
+chown -R openclaw:openclaw "$OPENCLAW_HOME/.openclaw"
+
+# Ollama (local model runtime)
+curl -fsSL https://ollama.com/install.sh | sh
+systemctl enable ollama
+systemctl start ollama
+su - openclaw -c 'nohup ollama pull glm-4.7-flash > /dev/null 2>&1 &' || true
+
+# Enable and start OpenClaw service (unit file landed via extra_files)
+systemctl daemon-reload
+systemctl enable openclaw.service
+systemctl start openclaw.servicediff --git a/modules/openclaw/terraform.tf b/modules/openclaw/terraform.tf
