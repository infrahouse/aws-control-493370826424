+}
+
+resource "aws_key_pair" "this" {
+  count      = var.key_name == null ? 1 : 0
+  key_name   = "openclaw"
+  public_key = tls_private_key.this[0].public_key_openssh
+}
+
+# ------------------------------------------------------------------------------
+# Website Pod - ALB, ASG, ACM, DNS, security groups
+# ------------------------------------------------------------------------------
+
+module "openclaw_pod" {
+  source  = "registry.infrahouse.com/infrahouse/website-pod/aws"
+  version = "5.17.0"
+
+  ami             = data.aws_ami.infrahouse_pro_noble.id
+  environment     = var.environment
+  service_name    = "openclaw"
+  zone_id         = var.zone_id
+  dns_a_records   = var.dns_a_records
+  subnets         = var.alb_subnet_ids
+  backend_subnets = var.backend_subnet_ids
+  key_pair_name   = var.key_name != null ? var.key_name : aws_key_pair.this[0].key_name
+  instance_type   = var.instance_type
+  root_volume_size = var.root_volume_size
+  userdata        = module.openclaw_userdata.userdata
+
+  # Single instance for stateful OpenClaw; scale out is not meaningful
+  asg_min_size = 1
+  asg_max_size = 1
+
+  # ALB settings
+  alb_name_prefix                    = "oclaw-"
+  alb_access_log_enabled             = true
+  alb_ingress_cidr_blocks            = var.allowed_cidrs
+  alb_healthcheck_path               = "/"
+  alb_healthcheck_port               = 5173
+  alb_healthcheck_response_code_matcher = "200-399"
+  alb_healthcheck_interval           = 30
+  alb_healthcheck_timeout            = 5
+  alb_healthcheck_healthy_threshold  = 2
+  alb_healthcheck_unhealthy_threshold = 3
+  enable_deletion_protection         = true
+  stickiness_enabled                 = true
+  target_group_port                  = 5173
+
+  # Instance profile permissions for Bedrock + Secrets Manager
+  instance_profile_permissions = data.aws_iam_policy_document.instance_permissions.json
+
+  tags = {
+    service = "openclaw"
+  }
+}
+
+# ------------------------------------------------------------------------------
+# Cloud-init userdata
+# ------------------------------------------------------------------------------
+
+module "openclaw_userdata" {
+  source  = "registry.infrahouse.com/infrahouse/cloud-init/aws"
+  version = "2.2.3"
+
+  environment = var.environment
+  role        = "openclaw"
+
+  extra_files = [
+    {
+      content     = file("${path.module}/openclaw.service")
+      path        = "/etc/systemd/system/openclaw.service"
+      permissions = "0644"
+    },
+    {
+      content = templatefile("${path.module}/setup-openclaw.sh.tftpl", {
+        secret_name          = aws_secretsmanager_secret.api_keys.name
+        openclaw_config_json = jsonencode(local.openclaw_config)
+        enable_bedrock       = local.enable_bedrock
+        region               = data.aws_region.this.name
+      })
+      path        = "/opt/openclaw/setup-openclaw.sh"
+      permissions = "0755"
+    },
+  ]
+
+  packages = [
+    "curl",
+    "jq",
+    "unzip",
+    "git",
+    "build-essential",
+  ]
+
+  pre_runcmd = [
+    # Node.js 22 LTS
+    "curl -fsSL https://deb.nodesource.com/setup_22.x | bash -",
+    "apt-get install -y nodejs",
+    "npm install -g npm@latest",
+
+    # Dedicated user
+    "useradd --system --create-home --shell /bin/bash openclaw || true",
+  ]
+
+  post_runcmd = [
+    "/opt/openclaw/setup-openclaw.sh",
+  ]
